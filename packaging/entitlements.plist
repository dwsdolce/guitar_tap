<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <!-- This edition ships as a Developer-ID-signed, notarized DMG (not the
             Mac App Store), so the App Sandbox is intentionally NOT enabled.
             Sandboxing blocked reading user-selected .guitartap files in the
             PyInstaller/PySide6 build (open panel grant not reaching open()).
             Microphone access works via TCC using NSMicrophoneUsageDescription
             in the bundle Info.plist (see packaging/guitar-tap.spec), which does
             not require the sandbox device.microphone entitlement.
             Only the hardened-runtime exception CPython needs is kept. -->
        <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
    </dict>
</plist>
