#!/bin/bash
#

# Run from the project root regardless of where this script is invoked from.
cd "$(dirname "$0")/.."

echo "Running build for `arch` architecure"

#===============================================
# Clean-up
#===============================================
rm -rf dist
rm -rf build

#===============================================
# Generate version_build from git commit count
#===============================================
./packaging/gen_version_build.sh
if [ $? -ne 0 ]; then
    echo "Generating version_build failed"
    exit 1
fi

#===============================================
# Run pyinstaller
#===============================================
# Get the full version (e.g. 1.0.245) matching what the spec file produces
VERSION="`cat src/guitar_tap/version`"
VERSION_BUILD="`cat src/guitar_tap/version_build`"
VERSION="${VERSION}.${VERSION_BUILD}"
echo "Creating installer for version ${VERSION}"
pyinstaller -y packaging/guitar-tap.spec
if [ $? -ne 0 ]; then
    echo "Running pyinstaller failed"
    exit 1
fi
