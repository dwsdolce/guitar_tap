coll = COLLECT(
    exe,
    a.binaries,
    a.zipfiles,
    a.datas,
    strip=False,
    upx=True,
    upx_exclude=[],
    name='guitar-tap',
)

package_version = f'{version}.0'
bundle_version = build if build else package_version  # build number or fallback

app = BUNDLE(coll,
    name='Guitar Tap.app',
    icon='src/guitar_tap/icons/guitar-tap.icns',
