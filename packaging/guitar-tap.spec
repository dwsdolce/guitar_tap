    ]

# Bundle 'version_build' file only if it exists (CI builds).
if _os.path.exists(build_file):
    added_files.append(('src/guitar_tap/version_build', '.'))

a = Analysis(
    ['src/guitar_tap/__main__.py'],
    pathex=['src/guitar_tap'],
    binaries=added_binaries,
    datas=added_files,
    hiddenimports=[],
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
)
pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

exe = EXE(
    pyz,
    a.scripts,
    [],
    exclude_binaries=True,
    name='guitar-tap',
    icon='src/guitar_tap/icons/guitar-tap.ico',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
