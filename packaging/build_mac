#!/bin/zsh

# Run from the project root regardless of where this script is invoked from.
cd "$(dirname "$0")/.."

# Usage:
#   build_mac          — defaults to dmg
#   build_mac dmg|pkg
#   build_mac help
#
if [[ $# == 0 ]]
then
    format="dmg"
elif [[ $# == 1 ]]
then
    if [[ "$1" == "help" ]]
    then
        echo "build_mac [dmg|pkg]"
        exit 0
    fi
    format="$1"
    if [[ $format != "dmg" && $format != "pkg" ]]
    then
        echo "Unknown installer format: $format"
        echo "build_mac [dmg|pkg]"
        exit 1
    fi
else
    echo "build_mac [dmg|pkg]"
    exit 1
fi


echo "Running build for `arch` architecure"

#===============================================
# Clean-up
#===============================================
rm -rf dist
rm -rf build

#===============================================
# Generate version_build from git commit count
#===============================================
./packaging/gen_version_build.sh
if [ $? -ne 0 ]; then
    echo "Generating version_build failed"
    exit 1
fi

#===============================================
# Run pyinstaller
#===============================================
# Get the full version (e.g. 1.0.245) matching what the spec file produces
VERSION="`cat src/guitar_tap/version`"
VERSION_BUILD="`cat src/guitar_tap/version_build`"
VERSION="${VERSION}.${VERSION_BUILD}"
echo "Creating installer for version ${VERSION}"
pyinstaller -y packaging/guitar-tap.spec
if [ $? -ne 0 ]; then
    echo "Running pyinstaller failed"
    exit 1
fi

echo "Removing dist/guitar-tap"
rm -rf dist/guitar-tap

#===============================================
# Create the format.
#===============================================
echo "Creating the ${format}"
installer_name="Guitar_Tap_V${VERSION}.${format}"
test -f $installer_name && rm $installer_name

if [[ $format == "dmg" ]]
then
    create-dmg \
        --volname "Guitar Tap $VERSION Install" \
        --background "src/guitar_tap/icons/guitar-tap-dmg.png" \
        --window-pos 1 1 \
        --icon "Guitar Tap.app" 190 350 \
        --window-size 640 535 \
        --icon-size 110 \
        --icon "Applications" 110 110 \
        --hide-extension "Applications" \
        --app-drop-link 450 360 \
        --format ULFO \
        --hdiutil-verbose \
        --volicon "src/guitar_tap/icons/guitar-tap.icns" \
        $installer_name \
        "dist/"
else
    #productbuild --sign "Developer ID Installer: David Smith (43QHHT3XK2)" --component dist/Guitar\ Tap.app /Applications $installer_name
    rm -rf packages
    mkdir packages
    pkgbuild --root ./dist \
        --component-plist packaging/guitar-tap.plist \
        --identifier "com.dolcesfogato.guitar-tap" \
        --version "${VERSION}" \
        --install-location "/Applications" \
        packages/GuitarTap.pkg
    productbuild --distribution ./packaging/guitar-tap.arm.dist  \
        --package-path ./packages \
        --sign "Developer ID Installer: David Smith (43QHHT3XK2)" \
        $installer_name
fi
if [ $? -ne 0 ]; then
    echo "Creating the ${format} failed"
    exit 1
fi

if [[ $format == "dmg" ]]
then
    echo "Signing the ${format}"
    /usr/bin/codesign -s "Developer ID Application: David Smith (43QHHT3XK2)" $installer_name
    if [ $? -ne 0 ]; then
        echo "Signing the ${format} failed"
        exit 1
    fi
fi

echo "Done Creating the ${format}"

#===============================================
# Notarize the format.
#===============================================
echo "Notarizing the ${format}"
xcrun notarytool submit $installer_name --wait --keychain-profile "notarytool-profile"
if [ $? -ne 0 ]; then
    echo "Notarizing the ${format} failed"
    exit 1
fi
echo "Done Notarizing the ${format}"

#===============================================
# Staple the format.
#===============================================
echo "Stapling the ${format}"
xcrun stapler staple $installer_name
if [ $? -ne 0 ]; then
    echo "Stapling the ${format} failed"
    exit 1
fi

echo "Done creating ${installer_name}"

